# Server
PORT=3001
JWT_SECRET=change-this-to-a-random-secret-string

# Plaid (optional - for bank sync)
# Get free Sandbox keys at https://dashboard.plaid.com/signup
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Gmail (optional - for email scanning)
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3001/api/gmail/callback

# SMTP (optional - for email notifications)
# Use SendGrid, Mailgun, Gmail App Password, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@subscription-auditor.app
