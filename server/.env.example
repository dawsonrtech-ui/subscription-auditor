# Copy to .env and fill in as needed. Everything below has a safe local
# default in server/index.js except DATABASE_URL and JWT_SECRET, which you
# should always set explicitly outside of local dev.

# Core
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/subaudit
JWT_SECRET=change-me
PORT=3001
BASE_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Plaid (leave blank to disable bank-linking features)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Gmail OAuth (leave blank to disable receipt-scanning features)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3001/api/gmail/callback

# Outbound email for renewal notifications (leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@subscription-auditor.app
