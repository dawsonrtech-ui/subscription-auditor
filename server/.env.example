# Copy to .env and fill in as needed. Everything below has a safe local
# default in server/index.js except DATABASE_URL and JWT_SECRET, which you
# should always set explicitly outside of local dev.

# Core
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/subaudit
# ^ Railway (and most PaaS hosts) provide DATABASE_URL automatically when
#   you add a Postgres service — you usually don't need to set this by hand
#   in production, only for local dev.
JWT_SECRET=change-me
PORT=3001
BASE_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Plaid (leave blank to disable bank-linking features)
# Get free Sandbox keys at https://dashboard.plaid.com/signup
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Gmail OAuth (leave blank to disable receipt-scanning features)
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3001/api/gmail/callback

# Outbound email for renewal notifications (leave blank to disable)
# Use SendGrid, Mailgun, a Gmail App Password, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@subscription-auditor.app

# Stripe billing (leave blank to disable — app runs fine without it, just
# with no paywall/trial enforcement)
# Create a Product + recurring Price in the Stripe Dashboard first, then
# put that Price's ID below. Get the webhook secret by creating an endpoint
# at <BASE_URL>/api/billing/webhook in the Stripe Dashboard (or via the
# Stripe CLI for local testing: `stripe listen --forward-to localhost:3001/api/billing/webhook`)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
TRIAL_DAYS=14
